{
  "name": "chrisjmears-sveltekit",
  "version": "1.0.0",
  "engines": {
    "node": "22.x"
  },
  "prettier": {},
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "npm run fetch-bsky",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "install-playwright": "npm run build && npx playwright install chromium",
    "generate-og": "node scripts/generate-og.mjs",
    "fetch-bsky": "node scripts/fetch-bsky.mjs",
    "list-frontmatter": "node scripts/list-frontmatter.mjs"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "mdsvex": "^0.12.6",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.0",
    "prettier-plugin-svelte": "^3.4.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex-svelte": "^1.2.0",
    "rehype-slug": "^6.0.0",
    "remark-abbr": "^1.4.2",
    "remark-github": "^12.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.2",
    "sorters": "^1.1.0",
    "svelte": "^5.46.4",
    "svelte-check": "^4.3.5",
    "svelte-cloudinary": "^2.3.1",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "type": "module",
  "dependencies": {
    "@lucide/svelte": "^1.21.0"
  }
}
