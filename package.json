{
  "name": "chrisjmears-sveltekit",
  "version": "1.0.0",
  "engines": {
    "node": "22.x"
  },
  "prettier": {},
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "npm run fetch-bsky",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "install-playwright": "npm run build && npx playwright install chromium",
    "generate-og": "node scripts/generate-og.mjs",
    "fetch-bsky": "node scripts/fetch-bsky.mjs",
    "list-frontmatter": "node scripts/list-frontmatter.mjs"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "cookie": "^1.1.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "mdsvex": "^0.12.6",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex-svelte": "^1.2.0",
    "rehype-slug": "^6.0.0",
    "remark-abbr": "^1.4.2",
    "remark-github": "^12.0.0",
    "remark-math": "^6.0.0",
    "sorters": "^1.1.0",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "svelte-cloudinary": "^2.3.1",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "type": "module"
}